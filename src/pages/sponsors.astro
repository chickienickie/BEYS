---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Sponsors | Bald Eagle Youth Soccer">
    <!-- SPONSOR INTRO -->
    <section class="sponsor-intro">
        <div class="container">
            <h2>Become a Sponsor</h2>
            <p>
                Bald Eagle Youth Soccer is looking for Sponsors! Your generosity helps us run fall and spring soccer
                seasons—we need YOU!
            </p>
            <p>
                We are a volunteer-run organization. Donations and sponsorships help us purchase supplies to maintain
                our home soccer fields, provide jerseys and essential gear, and keep registration costs affordable for
                local families.
            </p>
            <p>
                To become a sponsor, please reach out to us at:
            </p>
            <a class="sponsor-email" href="mailto:baldeagleyouthsoccer@gmail.com">
                baldeagleyouthsoccer@gmail.com
            </a>
        </div>
    </section>

    <!-- SPONSOR NEWS -->
    <section class="sponsor-news">
        <div class="container">
            <h2>Clash of the Cleats Tournament Sponsors</h2>
            <p>
                On Saturday, October 18, 2025, Bald Eagle Youth Soccer hosted the
                <strong>Clash of the Cleats Tournament</strong>, with the generous use of
                Penns Valley Youth Soccer's fields.
            </p>
            <p>
                We would like to thank the following sponsors who helped make this tournament a success for youth soccer
                players from Bald Eagle Youth Soccer, Bellefonte Soccer Association, and Penns Valley Youth Soccer.
            </p>
            <div class="sponsor-grid">
                <div class="sponsor-card">Ingram’s Market</div>
                <div class="sponsor-card">Arize Federal Credit Union</div>
                <div class="sponsor-card">Nittany Meat Market</div>
                <div class="sponsor-card">Weis Market (Bellefonte)</div>
                <div class="sponsor-card">Walmart (Benner Pike)</div>
                <div class="sponsor-card">Karen Day</div>
                <div class="sponsor-card">Alaina Lucas</div>
                <div class="sponsor-card">Todd and Elaine Warner</div>
                <div class="sponsor-card">Nancy Warner</div>
                <div class="sponsor-card">Danielle Fritchman</div>
            </div>
            <p class="volunteer-thanks">
                Thank you to our family and friend volunteers at the concession stands!
            </p>
        </div>
    </section>
</Layout>
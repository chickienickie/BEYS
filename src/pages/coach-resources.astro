---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Coach Resources | Bald Eagle Youth Soccer">
    <div class="coach-page">
    <!-- HERO -->
    <section class="page-hero">
        <h1>Coach Resources</h1>
    </section>

    <!-- QUICK NAV BUTTONS -->
<section class="coach-nav">
    <div class="container">
        <a href="#guidelines" class="primary-btn">Game Day Guidelines</a>
        <a href="#clearances" class="primary-btn">Clearances</a>
        <a href="#training" class="primary-btn">Training</a>
        <a href="#resources" class="primary-btn">Resources</a>
    </div>
  </section>
  <!-- FIELD & GAME DAY GUIDELINES -->
<section id="guidelines" class="coach-section">
    <div class="container">
      <h2>Field & Game Day Guidelines</h2>

      <div class="coach-card full-width">
        <h3>Game Format by Age Group</h3>
        <ul class="coach-list format-list">
          <li><strong>U7:</strong> 20 minutes (4x5 min or 2x10 min) • 4v4 (No Goalies) • Size 3 Ball</li>
          <li><strong>U9:</strong> 40 minutes (2x20 min or 4x10 min) • 5v5 (With Goalies) • Size 3 Ball</li>
          <li><strong>U11:</strong> 50 minutes (2x25 min) • 7v7 (With Goalies) • Size 4 Ball</li>
          <li><strong>U13:</strong> 60 minutes (2x30 min) • 9v9 (With Goalies) • Size 4 Ball</li>
        </ul>
      </div>
  
      <div class="coach-grid">
      <div class="coach-card">
        <h3>Field Care</h3>
        <ul class="coach-list">
          <li>Please do not allow players to dig in the goalie boxes.</li>
          <li>After each game, clean up all trash and remove corner flags.</li>
        </ul>
      </div>
    
      <div class="coach-card">
        <h3>Multiple Games Field Set Up</h3>
  
        <h4>U11 Games</h4>
        <ul class="coach-list">
          <li>Players stay in the middle between fields.</li>
          <li>Spectators remain outside field boundaries.</li>
        </ul>
  
        <h4>U9 Games</h4>
        <ul class="coach-list">
          <li>Field 2 must remain open if two games are scheduled.</li>
          <li>Do not use Field 2 during simultaneous games.</li>
        </ul>
      </div>
  
      <div class="coach-card">
        <h3>Referee Policy – Zero Tolerance</h3>
        <ul class="coach-list">
          <li>No dissent, sarcasm, or harassment toward referees.</li>
          <li>No arguing or aggressive questioning of calls.</li>
          <li>Discuss concerns politely at halftime or after the game with the opposing coach present.</li>
        </ul>
      </div>
  
      <div class="coach-card">
        <h3>Pre-Game Communication</h3>
        <ul class="coach-list">
          <li>Connect with the opposing coach before games.</li>
          <li>Discuss weather and scheduling if needed.</li>
          <li>Confirm player attendance with parents/guardians.</li>
        </ul>
      </div>
  
      <div class="coach-card">
        <h3>6–0 Rule (New)</h3>
        <p>If a team goes up by six goals, agree on an approach before the game.</p>
        <ul class="coach-list">
          <li>Turn the game into a scrimmage</li>
          <li>Rotate players into different positions</li>
          <li>Continue play as agreed</li>
        </ul>
      </div>
  
      <div class="coach-card">
        <h3>Equipment Checklist</h3>
        <ul class="coach-list">
          <li>Ball bag</li>
          <li>First aid kit</li>
          <li>Cones</li>
          <li>Pennies/Pinnies</li>
          <li>Goalie shirt and gloves (required)</li>
        </ul>
      </div>
  
      <div class="coach-card">
        <h3>Game Responsibilities</h3>
  
        <h4>Away Games</h4>
        <ul class="coach-list">
          <li>Bring one ball bag and one bleacher bench.</li>
          <li>Return borrowed equipment by the next practice.</li>
        </ul>
  
        <h4>Home Games</h4>
        <ul class="coach-list">
          <li>Remove all corner flags.</li>
          <li>Return bleachers to the shed.</li>
          <li>Clear all equipment and trash.</li>
        </ul>
      </div>
    
      <div class="coach-card">
        <h3>Communication</h3>
        <p>Use the schedule’s coach contact list for weather updates and coordination.</p>
      </div>
      </div>
      <p class ="thankyou"><strong>Thank you for volunteering your time and supporting the players this season!</strong></p>
    </div>
  </section>
    <!-- PA Required Clearances -->
    <section id="clearances" class="coach-section">
        <div class="container">
            <h2>PA Required Clearances</h2>
            <p>Thank you for volunteering to coach for Bald Eagle Youth Soccer. As a coach for a PA West affiliate,
                there are several mandatory requirements. Please complete all items below and upload the required
                documents.</p>

            <h3>Introduction to Grassroots Course</h3>
            <p>Via the USSF Digital Coaching Center. <br>
                Sign up for access to training. Under Courses, click <strong>Introduction</strong>. Take a screenshot of
                the completed course and email it.</p>
            <a class="resource-link" href="https://dcc.ussoccer.com/courses/available/16/details/1546"
                target="_blank">USSF Grassroots Course</a>

            <h3>SafeSport – Abuse Awareness</h3>
            <p>PA West Soccer requires all coaches/volunteers/referees/employees to complete abuse awareness training.
            </p>
            <a class="resource-link" href="https://learning.ussoccer.com/safe-soccer" target="_blank">SafeSport
                Training</a>

            <h3>PA State Police Criminal Record Check</h3>
            <p>Free for volunteers, valid 5 years. Complete and upload the report.</p>
            <a class="resource-link" href="https://epatch.pa.gov/home" target="_blank">PA State Police Report</a>

            <h3>Child Abuse History Report</h3>
            <p>PA Child Abuse History Clearance requests may be made online.</p>
            <a class="resource-link" href="https://www.compass.state.pa.us/cwis/public/home" target="_blank">Child Abuse
                History Report</a>

            <h3>FBI Criminal Background Check</h3>
            <p>Only required if you haven’t been a PA resident for 10+ years.</p>
            <p>Use Identogo volunteer service code: <strong>1KG6ZJ</strong>. Approx. cost: $21.35.</p>
            <a class="resource-link" href="https://uenroll.identogo.com/" target="_blank">FBI Clearance (Identogo)</a>

            <p>If you have been a PA resident for 10+ years, fill out the <strong>Volunteer Qualification
                    Affidavit</strong> (notarized).</p>

            <p><em>Note: Clearances are valid for 5 years and must be valid for the full season.</em></p>
        </div>
    </section>

    <!-- License & Training -->
    <section id="training" class="coach-section">
        <div class="container">
            <h2>License and Training</h2>
            <p>US Soccer Online Coaching Courses:</p>
            <ul class="coach-list">
                <li>U6 – 4v4 Course</li>
                <li>U8 – 4v4 Course</li>
                <li>U10 – 7v7 Course</li>
                <li>U12 – 9v9 Course</li>
            </ul>
            <a class="resource-link" href="https://learning.ussoccer.com/coach" target="_blank">US Soccer Coaching
                Courses</a>

            <h3>Safety Training</h3>
            <p>SafeSport training is free and requires an account. Upload the certificate when completing your volunteer
                form.</p>
        </div>
    </section>

    <!-- Uploading Documents -->
    <section class="coach-section">
        <div class="container">
            <h2>Uploading Documents</h2>
            <p>Login to your account on our website. Select the volunteer tab, choose your role, fill out the form, and
                attach/upload all required documents.</p>
                <a class="resource-link" href="https://login.stacksports.com/login?client_id=612b0399b1854a002e427f78&redirect_uri=https://core-api.bluesombrero.com/login/redirect/portal/6317&app_name=Bald+Eagle+Youth+Soccer&portalid=6317&instancekey=sports"
                target="_blank">Upload on Stack Sports</a>
        </div>
    </section>

    <!-- Additional Resources -->
    <section id="resources" class="coach-section">
        <div class="container">
            <h2>Additional Coaching Resources</h2>
            <a class="resource-link" href="https://www.soccerxpert.com" target="_blank">SoccerXpert Soccer Drills</a>
            <a class="resource-link" href="https://www.soccer-coaches.com" target="_blank">Soccer-Coaches.com</a>
        </div>
    </section>
</Layout>
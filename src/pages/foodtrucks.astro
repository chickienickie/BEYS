---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Soccer Saturday Food Trucks">
    <section class="schedule-section">
        <div class="container">
            <h2>Spring 2026 Soccer Saturdays Food Truck Schedule</h2>
            <div class="schedule-info">
                <img src="/foodtruck.png" class="announcement-icon" alt="Soccer Ball">
                <h3>Serving Hours</h3>
                <ul>
                    <li><strong>Time:</strong> 9:00 AM – 2:00 PM</li>
                    <li><strong>Location:</strong> Bald Eagle Youth Soccer Fields</li>
                </ul>
                <p class="schedule-note">
                    *Times and vendors subject to change.
                </p>
            </div>

            <!-- TABLE -->
            <div class="schedule-table-container">

---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Fundraisers | Bald Eagle Youth Soccer">
    <!-- HERO -->
    <section class="page-hero">
        <h1>Fundraisers</h1>
    </section>

    <!-- FUNDRAISER INFO -->
    <section class="fundraisers-section">
        <div class="container">
            <h2>League Fundraisers</h2>
            <p>Fundraising helps support equipment, fields, and league programs.</p>

            <div class="fundraiser-grid">
                <div class="fundraiser-card">
                    <h3>⚽ Spring Fundraiser: Marianna’s Hoagies & Pizzas!</h3>
                    <p>Our annual Spring Fundraiser is officially here! Help support our soccer season by selling (and
                        eating!) delicious Marianna’s favorites.</p>
                    <p><strong>Order Deadline:</strong> Turn in forms and payment at practice on Tuesday, April 21.</p>
                    <p><strong>Delivery Date:</strong> Friday, May 1 from 4:45 PM – 6:15 PM at the Unionville Boro
                        Building</p>
                    <a class="download-btn" href="/downloads/Marianna_s_Order_Form.pdf" download>Download Fundraiser
                        Form</a>
                </div>

                <div class="fundraiser-card">
                    <h3>The BEYS Fan Wear Store is Back!</h3>
                    <img src="/beyslogo.png" alt="BEYS Logo" class="fundraiser-img">
                    <p>We’re excited to announce that our Spring BEYS Fan Wear Store is open! Show your team spirit and grab some great BEYS gear.</p>
                    <p>The store will close <strong>April 12</strong>, so be sure to place your orders before then. Our goal is to distribute items at the <strong>April 23rd practice</strong>so everyone can wear their gear for the rest of the season.</p>
                    <p>Thanks for supporting BEYS and showing your team pride! 💙</p>
                    <a class="download-btn" href="https://pci.jotform.com/form/260904284317154 " download>Order Now
                        </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="BEYS Board | Bald Eagle Youth Soccer">
    <!-- HERO -->
    <section class="page-hero">
        <h1>BEYS Board</h1>
    </section>

    <!-- BOARD MEMBERS -->
    <section class="board-section">
        <div class="container">
            <h2>BEYS Board Members</h2>
            <div class="board-grid">
                <div class="board-card">
                    <h3>President</h3>
                    <p>Sara Hackett</p>
                </div>
                <div class="board-card">
                    <h3>Vice President</h3>
                    <p>Tracy Crestani</p>
                </div>
                <div class="board-card">
                    <h3>Treasurer / Referee Coordinator</h3>
                    <p>Lysse Lowe</p>
                </div>
                <div class="board-card">
                    <h3>Secretary</h3>
                    <p>Nickie Potter</p>
                </div>
                <div class="board-card">
                    <h3>Coaching Coordinator & Player Development</h3>
                    <p>Will Romine</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
        <div class="container">
            <h2>Contact the League</h2>
            <p>Email: <a href="mailto:baldeagleyouthsoccer@gmail.com">baldeagleyouthsoccer@gmail.com</a></p>
            <p>Follow us on Facebook: <a href="https://www.facebook.com/BaldEagleYouthSoccer" target="_blank">Bald Eagle
                    Youth Soccer</a></p>
        </div>
    </section>
</Layout>
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bald Eagle Youth Soccer">
    <!-- HERO -->
    <section class="hero">
        <div class="hero-overlay">
            <img src="/beyslogo.png" class="hero-logo" alt="BEYS Logo">
            <h1>Bald Eagle Youth Soccer</h1>
            <p>Building Skills. Building Confidence. Building Community.</p>
            <div class="hero-buttons">
                <a class="register-btn"
                    href="https://login.stacksports.com/login?client_id=612b0399b1854a002e427f78&redirect_uri=https://core-api.bluesombrero.com/login/redirect/portal/6317&app_name=Bald+Eagle+Youth+Soccer&portalid=6317&instancekey=sports"
                    target="_blank"
                    aria-label="Register Now (opens in a new tab)">
                    Register Now
                </a>
                <a class="field-btn" href="/fields">
                    Field Locations
                </a>
            </div>
        </div>
    </section>

    <!-- PROGRAMS -->
    <section id="programs" class="programs">
        <h2>Our Programs</h2>
        <div class="program-grid">
            <div class="program-card">
                <h3>U7</h3>
                <p>Practice Tues & Thurs</p>
                <p>6:00–7:00 PM</p>
                <p class="games">In-house games Thursday nights</p>
            </div>
            <div class="program-card">
                <h3>U9</h3>
                <p>Practice Tues & Thurs</p>
                <p>6:00–7:30 PM</p>
                <p class="games">Games Saturdays 9:30 AM</p>
            </div>
            <div class="program-card">
                <h3>U11</h3>
                <p>Practice Tues & Thurs</p>
                <p>6:00–7:30 PM</p>
                <p class="games">Games Saturdays 11:00 AM</p>
            </div>
            <div class="program-card">
                <h3>U13</h3>
                <p>Practice Tues & Thurs</p>
                <p>6:00–7:30 PM</p>
                <p class="games">Games Saturdays 12:30 PM</p>
            </div>
        </div>
    </section>

    <!-- ANNOUNCEMENTS -->
    <section class="announcements">
        <h2>Important Announcements</h2>
        <div class="announcement-cards">
            <!-- FUNDRAISER -->
            <div class="announcement">
                <img src="/fundraiserlogo.png" class="announcement-icon" alt="" aria-hidden="true">
                <span class="tag">Fundraiser</span>
                <h3>Spring Soccer Fundraiser</h3>
                <p><strong>Marianna’s Hoagies & Pizzas</strong></p>
                <p>
                    Our annual Spring Fundraiser is officially here! Help support our soccer season by selling (and
                    eating!) delicious Marianna’s favorites. All items are $10 each.
                </p>
                <p><strong>Order Deadline:</strong> Turn in forms and payment at practice on Tuesday, April 21.</p>
                <p><strong>Delivery Date:</strong> Friday, May 1 — pick up between 4:45–6:15 PM at the Unionville Boro
                    Building.</p>
                <p><strong>Download an Order Form:</strong></p>
                <a href="/downloads/Marianna_s_Order_Form.pdf" class="primary-btn" download>
                    Download Form
                </a>
            </div>
            <div class="announcement">
            <img src="/jersey.png" class="announcement-icon" alt="" aria-hidden="true">
            <span class="tag">Fan Wear</span>
            <h3>BEYS Spring Fan Wear</h3>
            <p><strong>Show Your BEYS Pride!</strong></p>
            <p>
                Our Spring BEYS Fan Wear Store is now open! Grab some great gear and represent the
                team at games and around town while supporting the program.
            </p>
            <p><strong>Store Closes:</strong> April 12</p>
            <p><strong>Estimated Distribution:</strong> April 23 practice</p>
            <p><strong>Shop the Fan Store:</strong></p>
            <a href="https://pci.jotform.com/form/260904284317154" class="primary-btn" target="_blank" rel="noopener">
                Shop Now
            </a>
            </div>
            <!-- CLEAT EXCHANGE -->
            <div class="announcement">
                <img src="/shoe.png" class="announcement-icon" alt="" aria-hidden="true">
                <span class="tag">Gear</span>
                <h3>Soccer Cleat Exchange</h3>
                <p>
                    Need cleats? We’ve got you covered! BEYS offers gently used cleats (worn for one season or less)
                    available free of charge.
                </p>
                <p>
                    Have cleats your child has outgrown? We gladly accept donations to help other players.
                </p>
                <p>
                    We also have a limited supply of shin guards and goalkeeper gloves—just let us know if you need any!
                </p>
                <p>Play, share, and support each other! 🦅⚽</p>
            </div>

            <!-- NEW PROGRAM UPDATE -->
            <div class="announcement">
                <img src="/soccerball.png" class="announcement-icon" alt="" aria-hidden="true">
                <span class="tag">New This Season</span>
                <h3>U11 & U13 Friendly Games</h3>
                <p>
                    We’re excited to introduce something <em>extra fun</em> this year!
                </p>
                <p>
                    U11 and U13 teams will take part in Friendly Thursday Games with Centre Soccer Association.
                </p>
                <p><strong>What to expect:</strong></p>
                <p>⚽ One additional friendly game per team</p>
                <p>📅 Played during a regular Thursday practice</p>
                <p>🤝 Fun, development-focused competition</p>
            </div>

            <!-- FOOD TRUCKS -->
            <div class="announcement">
                <img src="/foodtruck.png" class="announcement-icon" alt="" aria-hidden="true">
                <span class="tag">Game Day</span>
                <h3>Soccer Saturdays Food Trucks</h3>
                <p>
                    Make game day even better! Join us every Saturday for a rotating lineup of local food trucks.
                </p>
                <p><strong>Time:</strong> 9:00 AM – 2:00 PM</p>
                <p><strong>Location:</strong> Bald Eagle Youth Soccer Fields</p>
                <a href="/foodtrucks" class="primary-btn">
                    View Food Truck Schedule
                </a>
            </div>
        </div>
    </section>
</Layout>
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Field Directions | Bald Eagle Youth Soccer">
    <!-- HERO -->
    <section class="page-hero">
        <h1>Field Locations</h1>
    </section>

    <!-- FIELD MAP -->
    <section class="field-map-section">
        <div class="container">
            <h2>BEYS Field Map</h2>
            <p>Use this map to find your field on game day.</p>
            <div class="map-container">
                <img src="/BEYS Field Map.png" alt="Bald Eagle Youth Soccer Field Map">
            </div>
        </div>
    </section>

    <section class="field-map-section">
        <div class="container">
            <h2>Parking at our BEYS Home Fields</h2>
            <p>Parking Map for BEYS Home Soccer Fields <strong>(parking spots are highlighted in red)</strong>:</p>
            <p>Please refer to the ﬁeld map below for parking.  There is additional parking at the Unionville Boro playground, but there is to be <strong>NO PARKING</strong> where no parking signs are located, on the gravel path, or along any of the fencing. </p>
            <p>It is imperative that we do not receive parking violations from the Unionville Boro. Our organization does not own the fields, and the Boro is kind enough to grant us the opportunity to use the fields. Parking violations may result in field loss, which would be devastating to our program. </p>
            <div class="map-container">
                <img src="/BEYS Parking.png" alt="Bald Eagle Youth Soccer Parking Map">
            </div>
        </div>
    </section>

    <!-- FIELD DIRECTIONS -->
    <section class="fields-section">
        <div class="container">
            <h2>Field Directions</h2>
            <div class="field-grid">
                <div class="field-card">
                    <h3>Bellefonte: Walker Township</h3>
                    <p>1000 Sand Trap Dr<br>Bellefonte, PA 16823</p>
                    <a href="https://maps.google.com/?q=1000+Sand+Trap+Dr+Bellefonte+PA" target="_blank">Open in Google
                        Maps</a>
                </div>
                <div class="field-card">
                    <h3>Bellefonte: Governor's Park</h3>
                    <p>Governors Park Rd<br>Bellefonte, PA 16823</p>
                    <a href="https://maps.google.com/?q=Governors+Park+Rd+Bellefonte+PA" target="_blank">Open in Google
                        Maps</a>
                </div>
                <div class="field-card">
                    <h3>Bald Eagle Fields</h3>
                    <p>309 Apple Street<br>Julian, PA 16844</p>
                    <a href="https://maps.google.com/?q=309+Apple+St+Julian+PA" target="_blank">Open in Google Maps</a>
                </div>
                <div class="field-card">
                    <h3>PV Fields: Potter Elementary</h3>
                    <p>211 N Hoffer Ave<br>Centre Hall, PA 16828</p>
                    <a href="https://maps.google.com/?q=211+N+Hoffer+Ave+Centre+Hall+PA" target="_blank">Open in Google
                        Maps</a>
                </div>
                <div class="field-card">
                    <h3>West Branch Fields</h3>
                    <p>173 Havenview Dr<br>Lock Haven, PA 17745</p>
                    <a href="https://maps.google.com/?q=173+Havenview+Dr+Lock+Haven+PA" target="_blank">Open in Google
                        Maps</a>
                </div>
                <div class="field-card">
                    <h3>CSA: Homestead Park</h3>
                    <p>145 Farmstead Lane<br>State College, PA 16803</p>
                    <a href="https://maps.app.goo.gl/HQxw1AdVsgz9uinNA" target="_blank">Open in Google Maps</a>
                </div>
            </div>
        </div>
    </section>
</Layout>